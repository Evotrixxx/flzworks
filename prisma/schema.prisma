generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  passwordHash   String
  name           String
  role           String        @default("USER")
  listings       Listing[]
  favorites      Favorite[]
  savedSearches  SavedSearch[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Listing {
  id           String           @id @default(cuid())
  sellerId     String
  seller       User             @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  make         String
  model        String
  trim         String?
  yearMonth    String?
  year         Int
  price        Int
  priceEur     Int?
  mileage      Int
  fuel         String
  transmission String
  bodyType     String
  condition    String
  location     String
  description  String
  financingDetails String?
  financeTermMonths Int?
  seats        Int?
  doors        Int?
  color        String?
  upholsteryPrimary String?
  upholsterySecondary String?
  curbWeightKg Int?
  grossWeightKg Int?
  trunkVolumeLiters Int?
  climate      String?
  roof         String?
  engineDisplacementCcm Int?
  powerKw      Int?
  powerHp      Int?
  cylinderLayout String?
  driveType    String?
  gearboxDetail String?
  batteryCapacityPercent Int?
  acChargerType String?
  fastCharging Boolean @default(false)
  wltpRangeKm  Int?
  systemPowerKw Int?
  systemPowerHp Int?
  documentsType String?
  inspectionValidUntil String?
  frontTireSize String?
  rearTireSize String?
  interiorFeatures String?
  technicalFeatures String?
  exteriorFeatures String?
  multimediaFeatures String?
  extraInfo     String?
  historyInternationalEnabled Boolean @default(true)
  historyDomesticEnabled Boolean @default(true)
  vatDeductible Boolean @default(false)
  tradeInAvailable Boolean @default(false)
  availableImmediately Boolean @default(true)
  status       String           @default("PUBLISHED")
  photos       ListingPhoto[]
  favorites    Favorite[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([status, createdAt])
  @@index([make, model])
  @@index([price])
  @@index([year])
  @@index([mileage])
}

model ListingPhoto {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  path      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([listingId, sortOrder])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([listingId])
}

model SavedSearch {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  query     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
}

model IntranetAccessRequest {
  id               String    @id @default(cuid())
  module           String    @default("autopiac")
  name             String
  email            String
  ipAddress        String
  status           String    @default("PENDING")
  approveTokenHash String    @unique
  denyTokenHash    String    @unique
  claimTokenHash   String?   @unique
  approvedAt       DateTime?
  deniedAt         DateTime?
  accessedAt       DateTime?
  expiresAt        DateTime
  grantedDurationDays Int?
  createdAt        DateTime  @default(now())

  @@index([module, ipAddress, status, expiresAt])
  @@index([email, createdAt])
}

model IntranetIpBlock {
  id        String   @id @default(cuid())
  ipAddress String
  reason    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([ipAddress, expiresAt])
}

model PortfolioArticle {
  id          String   @id @default(cuid())
  folderName  String   @unique
  title       String
  description String?
  date        String   // extracted from folder name, e.g. "2026-11-17"
  visible     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
